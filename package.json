{
	"name": "@rbxts/quickzone",
	"version": "1.3.17",
	"description": "A high-performance, physics-free spatial query library for Roblox. Maintain 60 FPS with 1M+ zones.",
	"main": "src/init.lua",
	"scripts": {
		"build": "rbxtsc",
		"watch": "rbxtsc -w",
		"prepublishOnly": "npm run build",
		"postpublish": "npm run wally:publish",
		"wally:publish": "wally publish"
	},
	"keywords": [
		"zone",
		"quickzone"
	],
	"author": "AUTHOR_NAME",
	"repository": "github:LDGerrits/QuickZone",
	"license": "MIT",
	"types": "src/index.d.ts",
	"files": [
		"src",
		"!**/*.tsbuildinfo"
	],
	"publishConfig": {
		"access": "public"
	},
	"devDependencies": {
		"@rbxts/compiler-types": "^2.1.0-types.1",
		"@rbxts/types": "^1.0.664",
		"typescript": "^4.9.5"
	}
}
